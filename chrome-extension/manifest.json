{
  "manifest_version": 3,
  "name": "dabba AI Assistant",
  "version": "1.0.0",
  "description": "AI assistant powered by dabba — chat, explain, summarize any web page.",
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel",
    "contextMenus"
  ],
  "host_permissions": [
    "http://localhost:8080/*",
    "https://*/**"
  ],
  "side_panel": {
    "default_path": "sidebar/sidebar.html"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "dabba AI Assistant",
    "default_popup": "popup/popup.html"
  },
  "options_page": "options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
