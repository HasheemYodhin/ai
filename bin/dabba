#!/usr/bin/env python3

"""
Wrapper script to run dabba CLI from its main module.
This allows running "dabba" commands directly from terminal.
"""

import sys
import os

# Add the dabba directory to Python path
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from dabba.cli.main import main

if __name__ == "__main__":
    sys.exit(main())
