{
  "compilerOptions": {
    "module": "node16",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "rootDir": "src",
    // esbuild.js now handles all emission (bundled into out/extension.js) —
    // tsc's only job is type-checking (npm run check-types), so no .js/.d.ts
    // output should come from it at all.
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "moduleResolution": "node16",
    "types": ["node", "vscode"]
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "out", ".vscode-test"]
}
